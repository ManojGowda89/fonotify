{
  "name": "fonotify",
  "version": "2.0.0",
  "description": "Fire Once Notify Once - ultra lightweight SSE notifier",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "type": "module",
  "scripts": {
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build": "npm run build:esm && npm run build:cjs"
  },
  "keywords": [
    "sse",
    "notifier",
    "realtime",
    "events",
    "lightweight"
  ],
  "author": "Manoj Gowda",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "ioredis": "^5.10.1"
  }
}
