{
  "name": "fonotify",
  "version": "2.1.2",
  "description": "Fire Once Notify Once - ultra lightweight SSE notifier",
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./web": {
      "types": "./dist/esm/web.d.ts",
      "import": "./dist/esm/web.js",
      "require": "./dist/cjs/web.cjs"
    },
    "./app": {
      "types": "./dist/esm/app.d.ts",
      "import": "./dist/esm/app.js",
      "require": "./dist/cjs/app.cjs"
    }
  },
  "type": "module",
  "scripts": {
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && node scripts/fix-cjs-extensions.mjs",
    "build": "npm run build:esm && npm run build:cjs"
  },
  "keywords": [
    "sse",
    "notifier",
    "realtime",
    "events",
    "lightweight"
  ],
  "author": "Manoj Gowda",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "ioredis": "^5.10.1",
    "react-native-sse": "^1.2.1"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    },
    "react-native-sse": {
      "optional": true
    }
  }
}
